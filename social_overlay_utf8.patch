+                                                  setAllCategories(prev => [...prev, newCategory].sort((a, b) => a.title.localeCompare(b.title)));
+                                                  setCategoryInput('');
+                                                }
+                                              } catch (e) {
+                                                console.error(e);
+                                              }
+                                            }
+                                          }}
+                                        >
+                                          Create "{categoryInput}"
+                                        </button>
+                                      </CommandEmpty>
+                                      <CommandGroup heading="Suggestions">
+                                        {allCategories.map((category) => (
