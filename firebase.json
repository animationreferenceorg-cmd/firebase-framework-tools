{
  "functions": {
    "source": "functions"
  },
  "hosting": [
    {
      "site": "aniamtion-reference",
      "public": ".next",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "redirects": [
        { "source": "/.well-known/**", "type": 404 },
        { "source": "/**/phpinfo*", "type": 404 },
        { "source": "/**/phpinfo.php*", "type": 404 }
      ],
      "headers": [
        {
          "source": "/**",
          "headers": [
            { "key": "X-Content-Type-Options", "value": "nosniff" },
            { "key": "X-Frame-Options", "value": "DENY" }
          ]
        }
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "apphosting": {
    "source": ".",
    "region": "us-east1"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "storage": {
      "port": 9199
    },
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": true
    }
  }
}